POSTGRES_DB=textile_ai
POSTGRES_USER=textile
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_PORT=9001

GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
BUSINESS_SERVICE_PORT=3002
ORCHESTRATOR_SERVICE_PORT=8000
TEMPLATE_SERVICE_PORT=8001
FABRIC_SERVICE_PORT=8002
TRYON_SERVICE_PORT=8003

JWT_SECRET=
JWT_EXPIRES_IN=1d

ADMIN_DASHBOARD_EMAIL=
ADMIN_DASHBOARD_PASSWORD=

# Primary render provider
# PRIMARY_RENDER_PROVIDER options: openrouter | gemini | flux | together | replicate | stability | generic
PRIMARY_RENDER_PROVIDER=openrouter
PRIMARY_RENDER_API_KEY=
PRIMARY_RENDER_BASE_URL=https://openrouter.ai/api/v1
PRIMARY_RENDER_ENDPOINT=/black-forest-labs/FLUX.1-schnell
PRIMARY_RENDER_MODEL=black-forest-labs/FLUX.1-schnell
PRIMARY_RENDER_TIMEOUT=180
# OpenRouter-specific headers (ignored by other providers)
PRIMARY_RENDER_REFERER=http://localhost:3000
PRIMARY_RENDER_TITLE=Tailoring AI Platform

# Secondary / fallback provider (leave blank to disable fallback)
# SECONDARY_RENDER_PROVIDER options: openrouter | gemini | flux | together | replicate | stability | generic
SECONDARY_RENDER_PROVIDER=
SECONDARY_RENDER_API_KEY=
SECONDARY_RENDER_BASE_URL=
SECONDARY_RENDER_ENDPOINT=/images/generations
SECONDARY_RENDER_MODEL=
SECONDARY_RENDER_TIMEOUT=180

RENDER_OUTPUT_FORMAT=png
RENDER_IMAGE_COUNT=1
RENDER_USE_SEED=false
RENDER_SEED=42
RENDER_MAX_REFERENCES=4
RENDER_IMAGE_WIDTH=1024
RENDER_IMAGE_HEIGHT=1024

# Workflow 3 AI provider selection
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-image-1
OPENAI_MODEL_VERSION=latest

# FASHN
FASHN_API_KEY=

# Fal
FAL_API_KEY=
FAL_MODEL=kolors-virtual-tryon

# Replicate
REPLICATE_API_TOKEN=
REPLICATE_MODEL=catvton
REPLICATE_MODEL_VERSION=

TRYON_OUTPUT_FORMAT=svg
TRYON_IMAGE_WIDTH=1200
TRYON_IMAGE_HEIGHT=1600
TRYON_VALIDATE_CUSTOMER_IMAGE=true
TRYON_VALIDATE_OUTPUT=true
TRYON_ENABLE_FACE_RESTORATION=false
TRYON_ENABLE_UPSCALING=false
